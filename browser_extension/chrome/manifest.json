{
  "manifest_version": 3,
  "name": "SUM Exocortex",
  "version": "1.0",
  "description": "Continuous Digital Ingestion for the Quantum Knowledge OS",
  "action": {
    "default_popup": "src/popup.html"
  },
  "background": {
    "service_worker": "src/background.js"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "contextMenus"
  ],
  "host_permissions": [
    "http://localhost:8000/*"
  ]
}