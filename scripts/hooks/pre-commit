#!/usr/bin/env bash
# PORTFOLIO.md touch-reminder pre-commit hook.
#
# WARN-ONLY: prints a reminder, does NOT block the commit.
# If engineering code changed but PORTFOLIO.md did not, asks you to
# pause and decide whether the change is portfolio-relevant. Human
# judgment stays in the loop.
#
# The hard contract (metric rows must be labelled **proved** or
# **empirical-benchmark**) is enforced by the CI job
# `portfolio-contract` on every PR. This hook is the gentle
# prompt at author time, not a gate.
#
# Installed via:   scripts/install-hooks.sh
# Uninstalled via: git config --unset core.hooksPath

set -e

# Directories whose code changes typically justify a portfolio update.
# Docs dirs intentionally excluded — docs changes are portfolio-neutral.
WATCH_DIRS=(sum_cli internal scripts/bench Tests core-zig api single_file_demo standalone_verifier)

# Files staged for this commit.
STAGED=$(git diff --cached --name-only --diff-filter=ACMR)
if [ -z "$STAGED" ]; then
  exit 0
fi

# Does any staged file fall under a watched directory?
engineering_changed=0
for f in $STAGED; do
  for d in "${WATCH_DIRS[@]}"; do
    case "$f" in
      "$d"/*) engineering_changed=1 ;;
    esac
  done
done

if [ "$engineering_changed" -eq 0 ]; then
  exit 0
fi

# Is PORTFOLIO.md also staged?
portfolio_touched=0
for f in $STAGED; do
  if [ "$f" = "PORTFOLIO.md" ]; then
    portfolio_touched=1
    break
  fi
done

if [ "$portfolio_touched" -eq 1 ]; then
  exit 0
fi

# Warn, don't block.
cat >&2 <<'MSG'
ℹ  PORTFOLIO.md reminder — engineering code changed, PORTFOLIO.md did not.

   Is this change portfolio-relevant? (benchmark number, test count,
   horizon status, core capability reframing?) If yes, add a line to
   PORTFOLIO.md in this commit so the portfolio narrative stays
   honest against the code. If no, this is fine — carry on.

   Contract: CLAUDE.md → 'PORTFOLIO.md contract'.
   CI gate:  scripts/check_portfolio_contract.py (labels required on
             every metric-table row).

MSG
exit 0
