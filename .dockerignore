# Docker build context exclusions for SUM
# Keep in sync with .gitignore

# Version control
.git
.gitignore
.github

# Python environments & cache
.venv/
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.pyre/

# IDE & OS
.vscode/
.idea/
.DS_Store
*.swp

# Logs & temp
*.log
logs/
temp/
tmp/

# Documentation & config not needed at runtime
docs/
*.md
!requirements-prod.txt
.coveragerc
.gemini/
experiments.tsv

# Zig build artifacts (rebuilt in Docker Stage 1)
core-zig/.zig-cache/
core-zig/zig-out/

# Security (never ship)
.master_key
admin_api_key.txt
*.pem
*.key

# Test fixtures (not needed in production image)
Tests/benchmarks/
Tests/fixtures/

# Database files (created at runtime)
*.db
*.sqlite
*.sqlite3