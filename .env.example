# ─── SUM Quantum Knowledge OS — Environment Variables ────────────────
# Copy this file to .env and fill in your values.

# ── Required ──────────────────────────────────────────────
# OpenAI API Key (needed for NLP ingestion via /ingest endpoint)
# Math-only ingestion (/ingest/math) works without this.
OPENAI_API_KEY=sk-...

# ── Optional ──────────────────────────────────────────────
# JWT signing secret (default: a built-in fallback is used)
# Set this in production for secure multi-tenant JWT issuance.
SUM_JWT_SECRET=your_secret_key_minimum_32_bytes_long

# Server host/port (defaults shown)
SUM_HOST=0.0.0.0
SUM_PORT=8000

# Zig core shared library path (auto-detected if built)
# ZIG_LIB_PATH=core-zig/zig-out/lib/libsum_core.so

# Akashic Ledger DB path (defaults to akashic_ledger.db)
# AKASHIC_DB_PATH=akashic_ledger.db

# Spacy model (downloaded during setup)
# SPACY_MODEL=en_core_web_sm
